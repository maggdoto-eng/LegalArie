{
  "name": "legalairie-backend",
  "version": "0.0.1",
  "description": "LegalArie Backend - Legal Practice Management API",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node --loader ts-node/esm src/server.ts",
    "start": "node --loader ts-node/esm src/server.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "node --loader ts-node/esm src/scripts/migrate.ts",
    "db:seed": "node --loader ts-node/esm src/scripts/seed.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "socket.io": "^4.7.1",
    "firebase-admin": "^12.0.0",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.6.1",
    "redis": "^4.6.10",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "ts-node": "^10.9.1",
    "@types/node": "^20.9.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "eslint": "^8.53.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
